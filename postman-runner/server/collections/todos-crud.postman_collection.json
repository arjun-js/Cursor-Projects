{
  "info": {
    "_postman_id": "todos-crud-collection",
    "name": "Todos CRUD (JSONPlaceholder)",
    "description": "CRUD operations against https://jsonplaceholder.typicode.com/todos",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List todos",
      "request": {
        "method": "GET",
        "header": [],
        "url": "https://jsonplaceholder.typicode.com/todos"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns todos array', () => {",
              "    const todos = pm.response.json();",
              "    pm.expect(todos).to.be.an('array');",
              "    pm.expect(todos[0]).to.have.property('completed');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get todo by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "https://jsonplaceholder.typicode.com/todos/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Todo has title', () => {",
              "    pm.expect(pm.response.json()).to.have.property('title');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create todo",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Write Postman runner tests\",\n  \"completed\": false,\n  \"userId\": 1\n}"
        },
        "url": "https://jsonplaceholder.typicode.com/todos"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Todo created with id', () => {",
              "    pm.expect(pm.response.json()).to.have.property('id');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Patch todo completed",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"completed\": true\n}"
        },
        "url": "https://jsonplaceholder.typicode.com/todos/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Marked completed', () => {",
              "    pm.expect(pm.response.json().completed).to.eql(true);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Delete todo",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "https://jsonplaceholder.typicode.com/todos/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ]
}
