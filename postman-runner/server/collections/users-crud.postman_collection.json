{
  "info": {
    "_postman_id": "users-crud-collection",
    "name": "Users CRUD (JSONPlaceholder)",
    "description": "CRUD operations against https://jsonplaceholder.typicode.com/users",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List all users",
      "request": {
        "method": "GET",
        "header": [],
        "url": "https://jsonplaceholder.typicode.com/users"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Returns array of users', () => {",
              "    const data = pm.response.json();",
              "    pm.expect(data).to.be.an('array');",
              "    pm.expect(data.length).to.be.above(0);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get user by id",
      "request": {
        "method": "GET",
        "header": [],
        "url": "https://jsonplaceholder.typicode.com/users/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('User has expected fields', () => {",
              "    const user = pm.response.json();",
              "    pm.expect(user).to.have.property('id', 1);",
              "    pm.expect(user).to.have.property('name');",
              "    pm.expect(user).to.have.property('email');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create user",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Jane Runner\",\n  \"username\": \"jrunner\",\n  \"email\": \"jane@example.com\",\n  \"phone\": \"555-0100\",\n  \"website\": \"runner.dev\"\n}"
        },
        "url": "https://jsonplaceholder.typicode.com/users"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Returns created id', () => {",
              "    const user = pm.response.json();",
              "    pm.expect(user).to.have.property('id');",
              "    pm.collectionVariables.set('createdUserId', user.id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Update user",
      "request": {
        "method": "PUT",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": 1,\n  \"name\": \"Updated User\",\n  \"username\": \"updated\",\n  \"email\": \"updated@example.com\"\n}"
        },
        "url": "https://jsonplaceholder.typicode.com/users/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Name was updated', () => {",
              "    pm.expect(pm.response.json().name).to.eql('Updated User');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Delete user",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": "https://jsonplaceholder.typicode.com/users/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [{ "key": "createdUserId", "value": "" }]
}
