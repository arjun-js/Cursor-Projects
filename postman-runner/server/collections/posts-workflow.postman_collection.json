{
  "info": {
    "_postman_id": "posts-workflow-collection",
    "name": "Posts Workflow (JSONPlaceholder)",
    "description": "Blog posts read and write workflow via https://jsonplaceholder.typicode.com/posts",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List posts",
      "request": {
        "method": "GET",
        "header": [],
        "url": "https://jsonplaceholder.typicode.com/posts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Posts array returned', () => {",
              "    const posts = pm.response.json();",
              "    pm.expect(posts.length).to.be.above(0);",
              "    pm.collectionVariables.set('samplePostId', posts[0].id);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Filter posts by user",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/posts?userId=1",
          "protocol": "https",
          "host": ["jsonplaceholder", "typicode", "com"],
          "path": ["posts"],
          "query": [{ "key": "userId", "value": "1" }]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('All posts belong to user 1', () => {",
              "    pm.response.json().forEach(p => pm.expect(p.userId).to.eql(1));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get single post",
      "request": {
        "method": "GET",
        "header": [],
        "url": "https://jsonplaceholder.typicode.com/posts/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Post has title and body', () => {",
              "    const post = pm.response.json();",
              "    pm.expect(post).to.have.property('title');",
              "    pm.expect(post).to.have.property('body');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Create post",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"New Post from Runner\",\n  \"body\": \"Automated scenario execution.\",\n  \"userId\": 1\n}"
        },
        "url": "https://jsonplaceholder.typicode.com/posts"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201', () => pm.response.to.have.status(201));",
              "pm.test('Post id assigned', () => {",
              "    pm.expect(pm.response.json().id).to.be.a('number');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Update post title",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Revised Post Title\"\n}"
        },
        "url": "https://jsonplaceholder.typicode.com/posts/1"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200));",
              "pm.test('Title updated', () => {",
              "    pm.expect(pm.response.json().title).to.eql('Revised Post Title');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
  ],
  "variable": [{ "key": "samplePostId", "value": "1" }]
}
